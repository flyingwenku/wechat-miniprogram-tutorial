/* components/skeleton/skeleton.wxss */
.skeleton {
  display: flex;
  padding: 24rpx;
}
.sk-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--bg-hover);
  flex-shrink: 0;
  animation: shimmer 1.5s ease-in-out infinite;
}
.sk-content {
  flex: 1;
  margin-left: 20rpx;
}
.sk-title {
  width: 40%;
  height: 32rpx;
  border-radius: 8rpx;
  background: var(--bg-hover);
  margin-bottom: 16rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}
.sk-line {
  height: 24rpx;
  border-radius: 8rpx;
  background: var(--bg-hover);
  margin-bottom: 12rpx;
  animation: shimmer 1.5s ease-in-out infinite;
}
@keyframes shimmer {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}
