/* components/empty-state/empty-state.wxss */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon {
  font-size: 80rpx;
}
.empty-text {
  color: var(--text-tertiary);
  font-size: 28rpx;
  margin-top: 16rpx;
}
.empty-btn {
  margin-top: 24rpx;
  padding: 12rpx 48rpx;
  border: 1rpx solid var(--color-primary);
  color: var(--color-primary);
  border-radius: var(--radius-full);
  font-size: 26rpx;
}
