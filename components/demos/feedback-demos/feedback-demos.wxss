/* components/demos/feedback-demos/feedback-demos.wxss */
.demo-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 通用按钮 */
.demo-btn {
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  background: #f0f1f3;
  color: #333;
  font-size: 30rpx;
}
.demo-btn.primary {
  background: #4C8BF5;
  color: #fff;
}
.demo-btn.success {
  background: #34C759;
  color: #fff;
}
.demo-btn.danger {
  background: #FF3B30;
  color: #fff;
}
.demo-btn.warning {
  background: #FF9500;
  color: #fff;
}
.demo-btn.outline {
  border: 2rpx solid #4C8BF5;
  color: #4C8BF5;
  background: transparent;
}

.demo-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
}

/* 消息提示条 */
.banner {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  animation: slideDown 0.3s ease-out;
  padding-top: calc(24rpx + env(safe-area-inset-top));
}
.banner-success {
  background: #34C759;
}
.banner-error {
  background: #FF3B30;
}
.banner-warning {
  background: #FF9500;
}
.banner-info {
  background: #4C8BF5;
}
.banner-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  color: #fff;
  font-size: 24rpx;
  text-align: center;
  line-height: 40rpx;
  margin-right: 16rpx;
}
.banner-text {
  color: #fff;
  font-size: 28rpx;
  flex: 1;
}
@keyframes slideDown {
  from {
    transform: translateY(-100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
