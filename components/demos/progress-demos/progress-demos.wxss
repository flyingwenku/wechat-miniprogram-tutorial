/* components/demos/progress-demos/progress-demos.wxss */
.demo-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.demo-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
  margin-top: 8rpx;
}

/* 进度按钮 */
.progress-btns {
  display: flex;
  gap: 20rpx;
}
.prog-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  background: var(--bg-hover);
  color: var(--text-secondary);
  font-size: 28rpx;
}
.prog-btn.primary {
  background: var(--color-primary);
  color: #fff;
}

/* 圆形进度 */
.circle-demo {
  align-items: center;
}
.circle-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.circle-canvas {
  position: absolute;
  top: 0;
  left: 0;
}
.circle-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
}
.circle-percent {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
}
.circle-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 横向步骤条 */
.steps-horizontal {
  display: flex;
  position: relative;
}
.step-h {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.step-h-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}
.step-h.done .step-h-dot {
  background: var(--color-primary);
}
.step-h-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
  text-align: center;
}
.step-h.done .step-h-label {
  color: var(--text-primary);
  font-weight: 500;
}
.step-h-line {
  position: absolute;
  top: 24rpx;
  left: 50%;
  width: 100%;
  height: 2rpx;
  background: #ddd;
}
.step-h.done .step-h-line {
  background: var(--color-primary);
}

/* 竖向步骤条 */
.steps-vertical {
  padding-left: 8rpx;
}
.step-v {
  display: flex;
  align-items: flex-start;
  position: relative;
  padding-bottom: 32rpx;
  min-height: 80rpx;
}
.step-v-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ddd;
  flex-shrink: 0;
  margin-top: 6rpx;
  z-index: 1;
}
.step-v.done .step-v-dot {
  background: var(--color-primary);
}
.step-v-line {
  position: absolute;
  left: 9rpx;
  top: 26rpx;
  width: 2rpx;
  height: 100%;
  background: #ddd;
}
.step-v.done .step-v-line {
  background: var(--color-primary);
}
.step-v-content {
  margin-left: 20rpx;
  flex: 1;
}
.step-v-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  display: block;
}
.step-v-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

/* 骨架屏 */
.skeleton-demo {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.sk-row {
  display: flex;
  align-items: center;
}
.sk-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #eee;
  flex-shrink: 0;
}
.sk-content {
  flex: 1;
  margin-left: 20rpx;
}
.sk-title {
  height: 28rpx;
  border-radius: 8rpx;
  background: #eee;
  width: 30%;
  margin-bottom: 12rpx;
}
.sk-line {
  height: 22rpx;
  border-radius: 8rpx;
  background: #eee;
}
.shimmer {
  animation: shimmer-anim 1.5s ease-in-out infinite;
}
@keyframes shimmer-anim {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}

/* 真实内容 */
.real-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.rc-row {
  display: flex;
  align-items: center;
}
.rc-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}
.rc-info {
  margin-left: 20rpx;
  flex: 1;
}
.rc-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}
.rc-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}
.reload-btn {
  text-align: center;
  padding: 16rpx;
  border: 1rpx solid var(--color-primary);
  color: var(--color-primary);
  border-radius: 24rpx;
  font-size: 26rpx;
  margin-top: 8rpx;
}
