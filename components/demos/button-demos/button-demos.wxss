/* components/demos/button-demos/button-demos.wxss */
.demo-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

button {
  margin: 0;
}
button::after {
  border: none;
}

.demo-hint {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-top: 8rpx;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

/* 图文按钮 */
.img-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  background: #f0f1f3;
  color: #333;
}
.img-btn.primary {
  background: #4C8BF5;
  color: #fff;
}
.img-btn.success {
  background: #34C759;
  color: #fff;
}
.img-btn.danger {
  background: #FF3B30;
  color: #fff;
}
.img-btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}
.img-btn-text {
  font-size: 30rpx;
}

/* 禁用按钮 */
.custom-btn-demo {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}
.custom-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
}
.custom-btn.normal {
  background: #4C8BF5;
  color: #fff;
}
.custom-btn.disabled-state {
  background: #4C8BF5;
  color: #fff;
  opacity: 0.4;
}

/* 自定义样式按钮 */
.gradient-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
}
.shadow-btn {
  background: #4C8BF5;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  font-size: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 139, 245, 0.4);
}
.outline-btn {
  border: 2rpx solid #4C8BF5;
  color: #4C8BF5;
  border-radius: 48rpx;
  padding: 22rpx 0;
  text-align: center;
  font-size: 30rpx;
}
.round-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 48rpx;
  background: #FF9500;
  color: #fff;
  font-size: 28rpx;
}
.round-btn.purple {
  background: #5856D6;
}

/* FAB */
.fab-demo {
  position: relative;
}
.fab-demo-area {
  border: 1rpx dashed #ddd;
  border-radius: 16rpx;
  padding: 20rpx;
}
.fab-list-item {
  padding: 24rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #666;
}
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #4C8BF5;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(76, 139, 245, 0.5);
  z-index: 99;
}
.fab-plus {
  color: #fff;
  font-size: 56rpx;
  font-weight: 300;
}
