<!--components/demos/form-demos/form-demos.wxml-->

<!-- 单选框 -->
<view wx:if="{{controlId === 'form-radio'}}" class="demo-wrap">
  <radio-group bindchange="onRadioChange">
    <label class="radio-item" wx:for="{{['A','B','C','D']}}" wx:key="*this">
      <radio value="{{item}}" checked="{{radioValue === item}}" color="#4C8BF5"/>
      <text class="radio-label">选项 {{item}}</text>
    </label>
  </radio-group>
  <view class="result-box">当前选中：{{radioValue}}</view>
</view>

<!-- 复选框 -->
<view wx:elif="{{controlId === 'form-checkbox'}}" class="demo-wrap">
  <checkbox-group bindchange="onCheckboxChange">
    <label class="check-item" wx:for="{{['apple','banana','orange','grape']}}" wx:key="*this">
      <checkbox value="{{item}}" checked="{{checkValues.indexOf(item) > -1}}" color="#4C8BF5"/>
      <text class="check-label">
        {{item === 'apple' ? '苹果' : item === 'banana' ? '香蕉' : item === 'orange' ? '橙子' : '葡萄'}}
      </text>
    </label>
  </checkbox-group>
  <view class="result-box">已选：{{checkValues.length}} 项 — {{checkValues}}</view>
</view>

<!-- 开关 -->
<view wx:elif="{{controlId === 'form-switch'}}" class="demo-wrap">
  <view class="switch-row">
    <text class="switch-label">通知推送</text>
    <switch checked="{{switchVal}}" color="#4C8BF5" bindchange="onSwitchChange"/>
  </view>
  <view class="switch-row">
    <text class="switch-label">自动播放</text>
    <switch checked="{{switchVal2}}" color="#FF9500" bindchange="onSwitchChange2"/>
  </view>
  <view class="switch-row">
    <text class="switch-label">深色模式</text>
    <switch checked="{{false}}" color="#5856D6" type="checkbox"/>
  </view>
  <view class="result-box">通知：{{switchVal ? '开启' : '关闭'}} | 自动播放：{{switchVal2 ? '开启' : '关闭'}}</view>
</view>

<!-- 滑块 -->
<view wx:elif="{{controlId === 'form-slider'}}" class="demo-wrap">
  <view class="slider-demo">
    <view class="slider-label-row">
      <text class="slider-label">音量</text>
      <text class="slider-value">{{volume}}%</text>
    </view>
    <slider min="0" max="100" step="1" value="{{volume}}"
      activeColor="#4C8BF5" backgroundColor="#E8E8E8"
      block-size="24"
      bindchange="onSliderChange"
      bindchanging="onSliderChanging"/>
    <view class="slider-marks">
      <text>静音</text>
      <text>最大</text>
    </view>
  </view>
  <view class="volume-bar">
    <view class="volume-fill" style="width: {{volume}}%"></view>
  </view>
</view>

<!-- 输入框 -->
<view wx:elif="{{controlId === 'form-input'}}" class="demo-wrap">
  <view class="input-group">
    <text class="input-label">用户名</text>
    <input class="input-field" type="text" placeholder="请输入用户名"
      value="{{username}}" bindinput="onUsernameInput"/>
  </view>
  <view class="input-group">
    <text class="input-label">手机号</text>
    <input class="input-field" type="number" placeholder="请输入手机号"
      maxlength="11" value="{{phone}}" bindinput="onPhoneInput"/>
  </view>
  <view class="input-group">
    <text class="input-label">密码</text>
    <input class="input-field" password placeholder="请输入密码"
      value="{{password}}" bindinput="onPwdInput"/>
  </view>
  <view class="result-box" wx:if="{{username || phone}}">
    用户名：{{username || '未输入'}} | 手机：{{phone || '未输入'}}
  </view>
</view>

<!-- 文本域 -->
<view wx:elif="{{controlId === 'form-textarea'}}" class="demo-wrap">
  <view class="textarea-group">
    <textarea class="textarea-field" placeholder="请输入内容..."
      maxlength="200" auto-height
      value="{{content}}" bindinput="onContentInput"/>
    <text class="char-count">{{content.length}}/200</text>
  </view>
</view>

<!-- 日期选择器 -->
<view wx:elif="{{controlId === 'form-picker-date'}}" class="demo-wrap">
  <picker mode="date" value="{{date}}" start="2020-01-01" end="2030-12-31" bindchange="onDateChange">
    <view class="picker-row">
      <text class="picker-label">选择日期</text>
      <view class="picker-value-wrap">
        <text class="picker-value">{{date || '请选择'}}</text>
        <text class="picker-arrow">›</text>
      </view>
    </view>
  </picker>
  <picker mode="time" value="{{time}}" start="00:00" end="23:59" bindchange="onTimeChange">
    <view class="picker-row">
      <text class="picker-label">选择时间</text>
      <view class="picker-value-wrap">
        <text class="picker-value">{{time || '请选择'}}</text>
        <text class="picker-arrow">›</text>
      </view>
    </view>
  </picker>
  <view class="result-box" wx:if="{{date || time}}">
    日期：{{date || '未选'}} | 时间：{{time || '未选'}}
  </view>
</view>

<!-- 省市级联 -->
<view wx:elif="{{controlId === 'form-picker-region'}}" class="demo-wrap">
  <picker mode="region" value="{{region}}" bindchange="onRegionChange">
    <view class="picker-row">
      <text class="picker-label">所在地区</text>
      <view class="picker-value-wrap">
        <text class="picker-value">{{region[0]}} {{region[1]}} {{region[2]}}</text>
        <text class="picker-arrow">›</text>
      </view>
    </view>
  </picker>
  <view class="result-box">
    省：{{region[0]}} | 市：{{region[1]}} | 区：{{region[2]}}
  </view>
</view>

<!-- 评分 -->
<view wx:elif="{{controlId === 'form-rate'}}" class="demo-wrap">
  <view class="rate-container"
    bindtouchend="onRateLeave">
    <view class="rate-stars">
      <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this"
        class="star {{item <= rateHover ? 'active' : ''}}"
        data-val="{{item}}"
        bindtap="onRateTap"
        catchtouchstart="onRateHover">★</text>
    </view>
    <text class="rate-text">{{rate}} 分</text>
  </view>
  <view class="rate-desc">
    <text wx:if="{{rate === 0}}">请点击星星评分</text>
    <text wx:elif="{{rate <= 2}}">不太满意</text>
    <text wx:elif="{{rate <= 3}}">一般</text>
    <text wx:elif="{{rate <= 4}}">满意</text>
    <text wx:else>非常满意</text>
  </view>
</view>
