<!-- components/demos/hardware-demos/hardware-demos.wxml -->
<view class="hw-demo {{theme}}">

  <!-- 传感器类：三轴进度条 + 指南针 -->
  <block wx:if="{{demo.type === 'sensor'}}">
    <!-- 罗盘：指南针指针 -->
    <view wx:if="{{hardwareId === 'compass'}}" class="hw-compass-wrap">
      <view class="hw-compass">
        <view class="hw-compass-n">N</view>
        <view class="hw-needle" style="transform: rotate({{sensor.direction}}deg);"></view>
        <view class="hw-compass-center"></view>
      </view>
      <view class="hw-compass-read">方向 {{sensor.direction}}°　精度 {{sensor.accuracy}}</view>
    </view>

    <!-- 三轴进度条（加速度/陀螺仪/设备方向） -->
    <view wx:else class="hw-axes">
      <view class="hw-axis">
        <text class="hw-axis-label">{{hardwareId === 'deviceMotion' ? 'α' : 'X'}}</text>
        <view class="hw-axis-track"><view class="hw-axis-fill" style="width: {{axis.x}}%;"></view></view>
        <text class="hw-axis-val">{{sensor.x}}</text>
      </view>
      <view class="hw-axis">
        <text class="hw-axis-label">{{hardwareId === 'deviceMotion' ? 'β' : 'Y'}}</text>
        <view class="hw-axis-track"><view class="hw-axis-fill" style="width: {{axis.y}}%;"></view></view>
        <text class="hw-axis-val">{{sensor.y}}</text>
      </view>
      <view class="hw-axis">
        <text class="hw-axis-label">{{hardwareId === 'deviceMotion' ? 'γ' : 'Z'}}</text>
        <view class="hw-axis-track"><view class="hw-axis-fill" style="width: {{axis.z}}%;"></view></view>
        <text class="hw-axis-val">{{sensor.z}}</text>
      </view>
      <view class="hw-axis-hint">进度条长度表示三轴数值大小，旋转/倾斜手机即可看到变化</view>
    </view>

    <view class="hw-actions">
      <button class="hw-btn" bindtap="startDemo" wx:if="{{!running}}">开始监听</button>
      <button class="hw-btn ghost" bindtap="stopDemo" wx:else>停止</button>
    </view>
    <text class="hw-mode {{hardwareMode === 'real' ? 'real' : ''}}">当前：{{hardwareMode === 'real' ? '真机实时' : '模拟数据'}}</text>
  </block>

  <!-- 影像与音频类 -->
  <block wx:elif="{{demo.type === 'media'}}">
    <camera wx:if="{{hardwareId === 'camera' && hardwareMode === 'real'}}" class="hw-camera" device-position="back" flash="off"></camera>

    <image wx:if="{{mediaImg}}" src="{{mediaImg}}" mode="widthFix" class="hw-photo"></image>
    <view wx:if="{{scanResult}}" class="hw-result">扫码结果：{{scanResult}}</view>

    <!-- 录音：录制 + 回放闭环 -->
    <view wx:if="{{hardwareId === 'recorder'}}" class="hw-rec">
      <view wx:if="{{recState !== 'idle'}}" class="hw-rec-status">
        <text wx:if="{{recState === 'recording'}}" class="hw-rec-dot"></text>
        <text>{{recState === 'recording' ? '录音中' : '已录制'}}　{{recDuration}}s</text>
      </view>
      <view wx:if="{{recState === 'recorded'}}" class="hw-progress">
        <view class="hw-progress-fill" style="width: {{recProgress}}%;"></view>
      </view>
      <view wx:if="{{recState === 'recorded'}}" class="hw-result">点击播放，回听你的录音（已关闭静音开关，确保出声）</view>
    </view>

    <!-- 音频播放：本地示例 -->
    <view wx:if="{{hardwareId === 'audio'}}" class="hw-progress-wrap">
      <view class="hw-progress"><view class="hw-progress-fill" style="width: {{audioProgress}}%;"></view></view>
      <view class="hw-result">播放进度 {{audioProgress}}%</view>
    </view>

    <!-- 背景音频状态 -->
    <view wx:if="{{hardwareId === 'backgroundAudio' && bgState === 'playing'}}" class="hw-result">背景音频播放中（锁屏/切后台仍会继续）…</view>

    <view class="hw-actions">
      <button class="hw-btn" wx:if="{{hardwareId === 'camera'}}" bindtap="takePhoto">拍照</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'chooseMedia'}}" bindtap="chooseImg">选择图片</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'scanCode'}}" bindtap="scan">扫码</button>

      <!-- 录音控制 -->
      <button class="hw-btn" wx:if="{{hardwareId === 'recorder' && recState !== 'recording'}}" bindtap="startRec">开始录音</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'recorder' && recState === 'recording'}}" bindtap="stopRec">停止录音</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'recorder' && recState === 'recorded' && !recPlaying}}" bindtap="playRec">播放回听</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'recorder' && recState === 'recorded' && recPlaying}}" bindtap="pauseRec">暂停</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'recorder' && recState === 'recorded'}}" bindtap="startRec">重新录制</button>

      <!-- 音频播放控制 -->
      <button class="hw-btn" wx:if="{{hardwareId === 'audio' && audioState !== 'playing'}}" bindtap="playAudio">播放示例</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'audio' && audioState === 'playing'}}" bindtap="pauseAudio">暂停</button>

      <!-- 背景音频控制 -->
      <button class="hw-btn" wx:if="{{hardwareId === 'backgroundAudio' && bgState !== 'playing'}}" bindtap="playBg">后台播放</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'backgroundAudio' && bgState === 'playing'}}" bindtap="stopBg">停止 / 关闭</button>
    </view>
    <text class="hw-mode {{hardwareMode === 'real' ? 'real' : ''}}">当前：{{hardwareMode === 'real' ? '真机实时' : '模拟数据'}}</text>
  </block>

  <!-- 位置与网络类 -->
  <block wx:elif="{{demo.type === 'location'}}">
    <view class="hw-map">
      <text wx:if="{{hardwareId === 'getLocation'}}">{{loc || '点击获取当前位置'}}</text>
      <text wx:elif="{{hardwareId === 'network'}}">{{net || '点击获取网络类型'}}</text>
      <text wx:elif="{{hardwareId === 'wifi'}}">{{wifi || '点击获取 WiFi 信息'}}</text>
    </view>
    <view class="hw-actions">
      <button class="hw-btn" wx:if="{{hardwareId === 'getLocation'}}" bindtap="getLoc">获取位置</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'network'}}" bindtap="getNet">获取网络</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'wifi'}}" bindtap="getWifi">获取 WiFi</button>
    </view>
    <text class="hw-mode {{hardwareMode === 'real' ? 'real' : ''}}">当前：{{hardwareMode === 'real' ? '真机实时' : '模拟数据'}}</text>
  </block>

  <!-- 设备信息类 -->
  <block wx:elif="{{demo.type === 'device'}}">
    <view class="hw-result" wx:if="{{sys || battery || bright || clip}}">{{sys || battery || bright || clip}}</view>
    <view class="hw-actions">
      <button class="hw-btn" wx:if="{{hardwareId === 'systemInfo'}}" bindtap="getSys">获取系统信息</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'battery'}}" bindtap="getBattery">获取电量</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'screenBrightness'}}" bindtap="getBright">获取亮度</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'screenBrightness'}}" bindtap="setBright">设为 0.8</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'clipboard'}}" bindtap="setClip">写入剪贴板</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'clipboard'}}" bindtap="getClip">读取剪贴板</button>
    </view>
    <text class="hw-mode {{hardwareMode === 'real' ? 'real' : ''}}">当前：{{hardwareMode === 'real' ? '真机实时' : '模拟数据'}}</text>
  </block>

  <!-- 触感与外设类 -->
  <block wx:elif="{{demo.type === 'haptic'}}">
    <view wx:if="{{hardwareId === 'vibrate'}}" class="hw-vib-wrap">
      <view class="hw-vib {{vibState === 'vibrating' ? 'on' : ''}}">📳</view>
      <text class="hw-vib-tip">{{vibState === 'vibrating' ? '振动中…' : '点击下方按钮触发振动'}}</text>
    </view>
    <view class="hw-result" wx:if="{{ble}}">{{ble}}</view>
    <view class="hw-actions">
      <button class="hw-btn {{vibState === 'vibrating' ? 'on' : ''}}" wx:if="{{hardwareId === 'vibrate'}}" bindtap="vib">触发振动</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'soter'}}" bindtap="auth">发起认证</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'bluetooth'}}" bindtap="scanBle">扫描蓝牙</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'makePhoneCall'}}" bindtap="call">拨打电话</button>
    </view>
    <text class="hw-mode {{hardwareMode === 'real' ? 'real' : ''}}">当前：{{hardwareMode === 'real' ? '真机实时' : '模拟数据'}}</text>
  </block>

  <!-- 本地存储类 -->
  <block wx:elif="{{demo.type === 'storage'}}">
    <view class="hw-result" wx:if="{{fileContent}}">{{fileContent}}</view>
    <view class="hw-actions">
      <button class="hw-btn" wx:if="{{hardwareId === 'fileSystem'}}" bindtap="writeFile">写入文件</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'fileSystem'}}" bindtap="readFile">读取文件</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'saveImage'}}" bindtap="saveImg">保存图片到相册</button>
    </view>
    <text class="hw-mode {{hardwareMode === 'real' ? 'real' : ''}}">当前：{{hardwareMode === 'real' ? '真机实时' : '模拟数据'}}</text>
  </block>

  <!-- 近场通信类 -->
  <block wx:elif="{{demo.type === 'nfc'}}">
    <view wx:if="{{nfcCard}}" class="hw-nfc-card">
      <view class="hw-nfc-icon">NFC</view>
      <view class="hw-nfc-row">UID：{{nfcCard.uid}}</view>
      <view class="hw-nfc-row">类型：{{nfcCard.type}}</view>
    </view>
    <view class="hw-result" wx:if="{{nfcState}}">{{nfcState}}</view>
    <view class="hw-actions">
      <button class="hw-btn" bindtap="initNfc">初始化 HCE</button>
      <button class="hw-btn ghost" wx:if="{{nfcCard}}" bindtap="initNfc">再次读取</button>
    </view>
    <text class="hw-mode">模拟模式为虚拟卡片演示；真机（部分 Android）可真实读卡</text>
  </block>

  <!-- 其它类型占位（后续任务实现） -->
  <view wx:else class="hw-todo">
    <text>该硬件能力的实时体验正在开发中</text>
  </view>

</view>
