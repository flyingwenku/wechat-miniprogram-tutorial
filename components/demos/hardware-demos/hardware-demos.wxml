<!-- components/demos/hardware-demos/hardware-demos.wxml -->
<view class="hw-demo {{theme}}">

  <!-- 传感器类 -->
  <block wx:if="{{demo.type === 'sensor'}}">
    <view class="hw-readout" wx:if="{{hardwareId === 'gyroscope' || hardwareId === 'accelerometer'}}">
      <text class="hw-line">x: {{sensor.x}}</text>
      <text class="hw-line">y: {{sensor.y}}</text>
      <text class="hw-line">z: {{sensor.z}}</text>
    </view>
    <view class="hw-readout" wx:elif="{{hardwareId === 'compass'}}">
      <text class="hw-line">方向角: {{sensor.direction}}°</text>
      <text class="hw-line">精度: {{sensor.accuracy}}</text>
    </view>
    <view class="hw-readout" wx:elif="{{hardwareId === 'deviceMotion'}}">
      <text class="hw-line">α: {{sensor.alpha}}</text>
      <text class="hw-line">β: {{sensor.beta}}</text>
      <text class="hw-line">γ: {{sensor.gamma}}</text>
    </view>

    <view class="hw-actions">
      <button class="hw-btn" bindtap="startDemo" wx:if="{{!running}}">开始监听</button>
      <button class="hw-btn ghost" bindtap="stopDemo" wx:else>停止</button>
    </view>
    <text class="hw-mode {{hardwareMode === 'real' ? 'real' : ''}}">当前：{{hardwareMode === 'real' ? '真机实时' : '模拟数据'}}</text>
  </block>

  <!-- 影像与音频类 -->
  <block wx:elif="{{demo.type === 'media'}}">
    <camera wx:if="{{hardwareId === 'camera' && hardwareMode === 'real'}}" class="hw-camera" device-position="back" flash="off"></camera>

    <image wx:if="{{mediaImg}}" src="{{mediaImg}}" mode="widthFix" class="hw-photo"></image>
    <view wx:if="{{scanResult}}" class="hw-result">扫码结果：{{scanResult}}</view>
    <view wx:if="{{hardwareId === 'recorder'}}" class="hw-result">录音状态：{{recState}}　时长：{{recDuration}}s</view>
    <view wx:if="{{hardwareId === 'audio'}}" class="hw-result">播放进度：{{audioProgress}}%</view>

    <view class="hw-actions">
      <button class="hw-btn" wx:if="{{hardwareId === 'camera'}}" bindtap="takePhoto">拍照</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'chooseMedia'}}" bindtap="chooseImg">选择图片</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'scanCode'}}" bindtap="scan">扫码</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'recorder' && recState !== 'recording'}}" bindtap="startRec">开始录音</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'recorder' && recState === 'recording'}}" bindtap="stopRec">停止并播放</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'audio' && audioState !== 'playing'}}" bindtap="playAudio">播放</button>
      <button class="hw-btn ghost" wx:if="{{hardwareId === 'audio' && audioState === 'playing'}}" bindtap="pauseAudio">暂停</button>
      <button class="hw-btn" wx:if="{{hardwareId === 'backgroundAudio'}}" bindtap="playBg">后台播放</button>
    </view>
    <text class="hw-mode {{hardwareMode === 'real' ? 'real' : ''}}">当前：{{hardwareMode === 'real' ? '真机实时' : '模拟数据'}}</text>
  </block>

  <!-- 其它类型占位（后续任务实现） -->
  <view wx:else class="hw-todo">
    <text>该硬件能力的实时体验正在开发中</text>
  </view>

</view>
