/* components/demos/hardware-demos/hardware-demos.wxss */
.hw-demo {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 读数面板 */
.hw-readout {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  background: var(--bg-hover);
  border-radius: var(--radius-md);
  padding: 28rpx;
}
.hw-line {
  flex: 1 1 30%;
  min-width: 30%;
  font-size: var(--font-md);
  color: var(--text-primary);
  font-family: 'SF Mono', Menlo, Consolas, monospace;
  text-align: center;
}

/* 可视化环（模拟/真机数据动效） */
.hw-gauge {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  margin: 8rpx auto;
  border-radius: 50%;
  background: conic-gradient(var(--color-primary) calc(var(--angle, 0) * 1%), var(--bg-hover) 0);
  display: flex;
  align-items: center;
  justify-content: center;
}
.hw-gauge-inner {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-lg);
  color: var(--text-primary);
  font-weight: 600;
}

/* 操作按钮 */
.hw-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.hw-btn {
  flex: 1 1 auto;
  min-width: 200rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-md);
  border-radius: var(--radius-md);
  padding: 18rpx 0;
}
.hw-btn.ghost {
  background: var(--bg-hover);
  color: var(--text-secondary);
}
.hw-btn.on {
  background: var(--color-primary);
  box-shadow: 0 0 0 4rpx rgba(0,0,0,0.06);
}

/* 模式提示 */
.hw-mode {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  text-align: center;
}
.hw-mode.real {
  color: var(--color-success);
}

/* 媒体/位置等结果展示 */
.hw-result {
  background: var(--bg-hover);
  border-radius: var(--radius-md);
  padding: 24rpx;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  word-break: break-all;
  line-height: 1.7;
}
.hw-image {
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-md);
  background: var(--bg-hover);
}
.hw-map {
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-md);
  background: var(--bg-hover);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: var(--font-sm);
}

/* 开发中占位 */
.hw-todo {
  text-align: center;
  color: var(--text-tertiary);
  font-size: var(--font-sm);
  padding: 48rpx 0;
}

/* 摄像头预览 + 照片 */
.hw-camera {
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}
.hw-photo {
  width: 100%;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}

/* ============ 传感器：三轴进度条 ============ */
.hw-axes {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background: var(--bg-hover);
  border-radius: var(--radius-md);
  padding: 28rpx;
}
.hw-axis {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.hw-axis-label {
  width: 40rpx;
  text-align: center;
  font-size: var(--font-md);
  color: var(--text-secondary);
  font-weight: 600;
}
.hw-axis-track {
  flex: 1;
  height: 28rpx;
  background: var(--bg-card);
  border-radius: 999rpx;
  overflow: hidden;
}
.hw-axis-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), var(--color-success));
  border-radius: 999rpx;
  transition: width 0.12s linear;
}
.hw-axis-val {
  width: 110rpx;
  text-align: right;
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-family: 'SF Mono', Menlo, Consolas, monospace;
}
.hw-axis-hint {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  text-align: center;
}

/* ============ 传感器：指南针 ============ */
.hw-compass-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.hw-compass {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: var(--bg-hover);
  border: 4rpx solid var(--bg-card);
}
.hw-compass-n {
  position: absolute;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: var(--font-sm);
  color: #e54d42;
  font-weight: 700;
}
.hw-needle {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 10rpx;
  height: 200rpx;
  margin-left: -5rpx;
  margin-top: -100rpx;
  transform-origin: 50% 50%;
  border-radius: 10rpx;
  background: linear-gradient(180deg, #e54d42 0 50%, #4a4a4a 50% 100%);
}
.hw-compass-center {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 24rpx;
  background: var(--color-primary);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}
.hw-compass-read {
  font-size: var(--font-md);
  color: var(--text-primary);
}

/* ============ 录音 / 播放进度 ============ */
.hw-rec {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.hw-rec-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: var(--font-md);
  color: var(--text-primary);
}
.hw-rec-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #e54d42;
  animation: hw-pulse 1s infinite;
}
@keyframes hw-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.2; }
}
.hw-progress {
  width: 100%;
  height: 16rpx;
  background: var(--bg-hover);
  border-radius: 999rpx;
  overflow: hidden;
}
.hw-progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 999rpx;
  transition: width 0.12s linear;
}
.hw-progress-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* ============ 振动反馈 ============ */
.hw-vib-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
}
.hw-vib {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: var(--bg-hover);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
}
.hw-vib.on {
  animation: hw-shake 0.15s linear 0s 4;
  background: var(--color-primary);
}
@keyframes hw-shake {
  0%, 100% { transform: translate(0, 0); }
  25% { transform: translate(-8rpx, 0); }
  75% { transform: translate(8rpx, 0); }
}
.hw-vib-tip {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* ============ NFC 模拟卡片 ============ */
.hw-nfc-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  background: var(--bg-hover);
  border: 2rpx dashed var(--color-primary);
  border-radius: var(--radius-md);
  padding: 28rpx;
}
.hw-nfc-icon {
  align-self: flex-start;
  background: var(--color-primary);
  color: #fff;
  font-size: var(--font-xs);
  font-weight: 700;
  letter-spacing: 2rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}
.hw-nfc-row {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-family: 'SF Mono', Menlo, Consolas, monospace;
}
