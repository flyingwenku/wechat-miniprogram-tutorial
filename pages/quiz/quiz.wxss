/* pages/quiz/quiz.wxss */
.quiz-page {
  padding: 20rpx 24rpx 60rpx;
}

/* 统计卡片 */
.stats-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 36rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-primary);
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: var(--border-light);
}

.stats-progress {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: var(--bg-hover);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4facfe, #00f2fe);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

/* 模式卡片 */
.mode-card {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.random-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.wrong-card {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.mode-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
}

.mode-info {
  flex: 1;
}

.mode-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.4;
}

.mode-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
}

.mode-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

.wrong-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #ffffff;
  color: #f5576c;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  text-align: center;
}

/* 区块标题 */
.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 32rpx 0 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 分类卡片 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.cat-header {
  display: flex;
  align-items: center;
}

.cat-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.cat-info {
  flex: 1;
}

.cat-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}

.cat-desc {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.cat-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
}

.cat-stats {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  gap: 12rpx;
}

.cat-progress-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.cat-progress-bar {
  flex: 1;
  height: 8rpx;
  background: var(--bg-hover);
  border-radius: 4rpx;
  overflow: hidden;
}

.cat-progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.cat-rate {
  font-size: 22rpx;
  color: var(--color-primary);
  font-weight: 600;
  white-space: nowrap;
}

.cat-not-started {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* 清除记录按钮 */
.clear-btn {
  text-align: center;
  padding: 24rpx;
  margin-top: 40rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}
