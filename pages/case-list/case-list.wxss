/* pages/case-list/case-list.wxss */
.page {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
}

.intro-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--color-primary);
}
.intro-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

.case-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.case-card {
  display: flex;
  align-items: flex-start;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}
.case-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.case-icon {
  font-size: 36rpx;
}
.case-info {
  flex: 1;
  margin-left: 20rpx;
}
.case-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.case-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 6rpx;
  display: block;
}
.case-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}
.case-tag {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  background: var(--bg-hover);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}
.case-arrow {
  font-size: 40rpx;
  color: var(--text-tertiary);
  margin-left: 12rpx;
  margin-top: 16rpx;
}

.footer-note {
  text-align: center;
  padding: 32rpx 0;
  color: var(--text-tertiary);
  font-size: var(--font-xs);
}
