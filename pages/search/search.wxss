/* pages/search/search.wxss */
.page { min-height: 100vh; padding: 0 32rpx 48rpx; }

.search-input-bar { margin-bottom: 24rpx; }
.search-input-wrap {
  display: flex; align-items: center;
  background: var(--bg-card); border-radius: var(--radius-full);
  padding: 16rpx 28rpx; box-shadow: var(--shadow-card);
}
.si-icon { font-size: 32rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: var(--font-md); }
.si-clear { font-size: 28rpx; color: var(--text-tertiary); padding: 8rpx; }

.result-count { font-size: 24rpx; color: var(--text-tertiary); margin-bottom: 16rpx; }
.result-item {
  display: flex; align-items: center;
  background: var(--bg-card); border-radius: var(--radius-lg);
  padding: 24rpx; margin-bottom: 16rpx; box-shadow: var(--shadow-card);
}
.result-icon { font-size: 40rpx; margin-right: 20rpx; }
.result-info { flex: 1; }
.result-name { font-size: var(--font-lg); font-weight: 600; color: var(--text-primary); display: block; }
.result-desc { font-size: var(--font-sm); color: var(--text-secondary); margin-top: 4rpx; display: block; }
.result-cat { font-size: 22rpx; color: var(--color-primary); margin-top: 8rpx; display: block; }
.result-arrow { font-size: 40rpx; color: var(--text-tertiary); }

.search-empty { padding-top: 80rpx; }
.search-tip { padding-top: 60rpx; }
.tip-title { font-size: var(--font-md); color: var(--text-secondary); margin-bottom: 20rpx; }
.tip-tags { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tip-tag {
  padding: 12rpx 32rpx; border-radius: var(--radius-full);
  background: var(--bg-card); color: var(--text-secondary);
  font-size: var(--font-sm); box-shadow: var(--shadow-card);
}
