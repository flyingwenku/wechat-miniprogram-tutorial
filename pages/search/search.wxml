<!--pages/search/search.wxml-->
<view class="page {{theme}}">
  <nav-bar title="搜索" showBack="{{true}}"
    bgColor="{{theme === 'dark' ? '#1e1e1e' : '#ffffff'}}"
    textColor="{{theme === 'dark' ? '#e8e8e8' : '#1a1a1a'}}" />

  <view class="search-input-bar">
    <view class="search-input-wrap">
      <text class="si-icon">🔍</text>
      <input class="search-input" placeholder="搜索控件名称..."
        value="{{keyword}}" bindinput="onInput" focus="{{true}}"/>
      <text class="si-clear" wx:if="{{keyword}}" bindtap="onClear">✕</text>
    </view>
  </view>

  <view class="search-results" wx:if="{{results.length > 0}}">
    <view class="result-count">找到 {{results.length}} 个结果</view>
    <view class="result-item hover-scale"
      wx:for="{{results}}" wx:key="id"
      data-id="{{item.id}}" bindtap="goToDetail">
      <text class="result-icon">{{item.categoryIcon}}</text>
      <view class="result-info">
        <text class="result-name">{{item.name}}</text>
        <text class="result-desc">{{item.desc}}</text>
        <text class="result-cat">{{item.categoryName}}</text>
      </view>
      <text class="result-arrow">›</text>
    </view>
  </view>

  <view class="search-empty" wx:if="{{searched && results.length === 0}}">
    <empty-state icon="🔍" text="未找到相关控件" />
  </view>

  <view class="search-tip" wx:if="{{!searched}}">
    <text class="tip-title">试试搜索</text>
    <view class="tip-tags">
      <text class="tip-tag">按钮</text>
      <text class="tip-tag">表单</text>
      <text class="tip-tag">轮播图</text>
      <text class="tip-tag">弹幕</text>
      <text class="tip-tag">骨架屏</text>
    </view>
  </view>
</view>
