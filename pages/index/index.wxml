<!--pages/index/index.wxml-->
<view class="page {{theme}}">
  <nav-bar title="控件教程" bgColor="{{theme === 'dark' ? '#1e1e1e' : '#ffffff'}}" textColor="{{theme === 'dark' ? '#e8e8e8' : '#1a1a1a'}}" />

  <!-- 搜索入口 -->
  <view class="search-bar hover-opacity" bindtap="goToSearch">
    <text class="search-icon">🔍</text>
    <text class="search-placeholder">搜索控件名称...</text>
  </view>

  <!-- 统计概览 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">控件总数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{categories.length}}</text>
      <text class="stat-label">分类</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">100%</text>
      <text class="stat-label">开源可商用</text>
    </view>
  </view>

  <!-- 实战案例入口 -->
  <view class="section-header">
    <text class="section-title-text">实战案例</text>
    <text class="section-more" bindtap="goToCaseList">全部 ›</text>
  </view>

  <view class="case-entry hover-scale" bindtap="goToCaseList">
    <view class="case-entry-left">
      <text class="case-entry-icon">🚀</text>
      <view class="case-entry-info">
        <text class="case-entry-title">8个真实业务场景</text>
        <text class="case-entry-desc">登录注册 · 商品列表 · 商品详情 · 订单表单 · 个人中心 · 搜索 · 聊天 · 数据看板</text>
      </view>
    </view>
    <text class="case-entry-arrow">›</text>
  </view>

  <!-- 分类列表 -->
  <view class="section-header">
    <text class="section-title-text">控件分类</text>
  </view>

  <view class="category-grid">
    <view class="category-card hover-scale"
      wx:for="{{categories}}" wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToCategory"
      style="border-left: 6rpx solid {{item.color}};">
      <view class="cat-icon-wrap" style="background: {{item.color}}1a;">
        <text class="cat-icon">{{item.icon}}</text>
      </view>
      <view class="cat-info">
        <view class="cat-header">
          <text class="cat-name">{{item.name}}</text>
          <text class="cat-count">{{item.count}}个</text>
        </view>
        <text class="cat-desc">{{item.description}}</text>
      </view>
      <text class="cat-arrow">›</text>
    </view>
  </view>

  <!-- 最近浏览 -->
  <view class="section-header" wx:if="{{recentList.length > 0}}">
    <text class="section-title-text">最近浏览</text>
    <text class="section-more" bindtap="goToSearch">全部</text>
  </view>

  <view class="recent-list" wx:if="{{recentList.length > 0}}">
    <view class="recent-item hover-opacity"
      wx:for="{{recentList}}" wx:key="id"
      data-id="{{item.id}}"
      bindtap="goToDetail">
      <text class="recent-name">{{item.name}}</text>
      <text class="recent-arrow">›</text>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer-note">
    <text>交互控件教程小程序 · 完整源码</text>
  </view>
</view>
