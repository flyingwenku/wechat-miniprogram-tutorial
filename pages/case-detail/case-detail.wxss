/* pages/case-detail/case-detail.wxss */
.page {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
}

/* 案例头部 */
.case-header {
  margin-bottom: 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
}
.case-header-top {
  display: flex;
  align-items: flex-start;
}
.case-header-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}
.case-header-info {
  flex: 1;
}
.case-header-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}
.case-header-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}
.case-header-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}
.case-header-tag {
  font-size: var(--font-xs);
  color: var(--color-primary);
  background: var(--bg-hover);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius-full);
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  border-radius: var(--radius-full);
  transition: var(--transition);
}
.tab-item.active {
  background: var(--color-primary);
  color: #fff;
  font-weight: 600;
}

/* Tab 内容 */
.tab-content {
  min-height: 400rpx;
}

/* 演示区域 */
.demo-area {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  min-height: 400rpx;
  position: relative;
  overflow: hidden;
}

/* 结构说明 */
.structure-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.structure-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--color-primary);
}
.structure-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}
.structure-content {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.7;
}

/* 代码区域 */
.code-area {
  display: flex;
  flex-direction: column;
}

/* 提示区域 */
.tips-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--color-warning);
}
.tips-text {
  font-size: var(--font-md);
  color: var(--text-secondary);
  line-height: 1.8;
}
