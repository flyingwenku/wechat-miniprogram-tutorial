/* pages/quiz-practice/quiz-practice.wxss */
.practice-page {
  padding: 20rpx 24rpx 120rpx;
  min-height: 100vh;
}

/* 进度条区域 */
.progress-section {
  margin-bottom: 28rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-current {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.progress-correct {
  font-size: 26rpx;
  color: var(--color-success, #07c160);
}

.progress-track {
  height: 8rpx;
  background: var(--bg-hover);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 题目卡片 */
.question-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.question-meta {
  margin-bottom: 20rpx;
}

.q-category {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-light, #e8f0fe);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.question-text {
  font-size: 34rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.6;
}

/* 选项列表 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border: 2rpx solid var(--border-light, #eee);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  transition: all 0.2s ease;
}

.option-item:active {
  background: var(--bg-hover);
}

.option-correct {
  border-color: #07c160;
  background: #f0fff4;
}

.option-wrong {
  border-color: #ee0a24;
  background: #fff0f0;
}

.option-dim {
  opacity: 0.5;
}

.option-label {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-hover);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-correct .option-label {
  background: #07c160;
  color: #fff;
}

.option-wrong .option-label {
  background: #ee0a24;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

.option-icon {
  font-size: 36rpx;
  color: #07c160;
  font-weight: 600;
  margin-left: 16rpx;
}

.icon-wrong {
  color: #ee0a24;
}

/* 解析卡片 */
.explanation-card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-top: 24rpx;
  border-left: 6rpx solid var(--color-primary);
}

.explanation-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.result-badge {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.badge-correct {
  background: #f0fff4;
  color: #07c160;
}

.badge-wrong {
  background: #fff0f0;
  color: #ee0a24;
}

.explanation-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.explanation-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.explanation-action {
  margin-top: 20rpx;
}

.action-link {
  font-size: 26rpx;
  color: var(--color-primary);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.next-btn {
  background: var(--color-primary);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.next-btn:active {
  opacity: 0.85;
}

/* 退出按钮 */
.quit-btn {
  text-align: center;
  padding: 24rpx;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}
