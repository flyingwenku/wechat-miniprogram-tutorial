/* pages/quiz-result/quiz-result.wxss */
.result-page {
  padding: 20rpx 24rpx 60rpx;
}

/* 得分卡片 */
.score-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 48rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 32rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.score-num {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
}

.score-unit {
  font-size: 24rpx;
  margin-left: 4rpx;
}

.score-level {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.score-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.score-detail {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.detail-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.detail-divider {
  color: var(--border-light);
  font-size: 24rpx;
}

/* 薄弱知识域 */
.weak-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-sub {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.weak-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.weak-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
}

.weak-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.weak-info {
  flex: 1;
}

.weak-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.weak-desc {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.weak-rate {
  font-size: 32rpx;
  font-weight: 700;
  color: #ee0a24;
}

/* 操作按钮 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-btn {
  text-align: center;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.primary-btn {
  background: var(--color-primary);
  color: #fff;
}

.primary-btn:active {
  opacity: 0.85;
}

.secondary-btn {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.text-btn {
  color: var(--text-tertiary);
  font-size: 28rpx;
  padding: 16rpx;
}
