/* pages/about/about.wxss */
.page { min-height: 100vh; padding: 0 32rpx 48rpx; }

.about-logo {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 0;
}
.logo-icon {
  width: 120rpx; height: 120rpx; border-radius: 28rpx;
  background: linear-gradient(135deg, #4C8BF5, #6BA0F7);
  display: flex; align-items: center; justify-content: center;
  font-size: 60rpx; box-shadow: 0 8rpx 24rpx rgba(76,139,245,0.3);
}
.logo-title { font-size: 40rpx; font-weight: 700; color: var(--text-primary); margin-top: 20rpx; }
.logo-version { font-size: 26rpx; color: var(--text-tertiary); margin-top: 4rpx; }

.about-section {
  background: var(--bg-card); border-radius: var(--radius-lg);
  padding: 28rpx; margin-bottom: 24rpx; box-shadow: var(--shadow-card);
}
.section-title { font-size: var(--font-lg); font-weight: 600; color: var(--text-primary); display: block; margin-bottom: 16rpx; }
.section-text { font-size: var(--font-md); color: var(--text-secondary); line-height: 1.7; }

.feature-list { display: flex; flex-direction: column; gap: 16rpx; }
.feature-item { display: flex; align-items: center; }
.feature-icon { font-size: 28rpx; margin-right: 12rpx; }
.feature-text { font-size: var(--font-md); color: var(--text-secondary); }

.tech-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tech-tag {
  padding: 8rpx 24rpx; border-radius: var(--radius-full);
  background: var(--bg-tag); color: var(--color-primary);
  font-size: var(--font-sm);
}

.contact-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 0;
}
.contact-label { font-size: var(--font-md); color: var(--text-secondary); }
.contact-value { font-size: var(--font-md); color: var(--color-primary); }

.about-footer {
  text-align: center; padding: 32rpx 0;
  color: var(--text-tertiary); font-size: var(--font-xs);
  display: flex; flex-direction: column; gap: 4rpx;
}
