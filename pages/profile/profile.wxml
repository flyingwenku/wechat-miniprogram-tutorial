<!--pages/profile/profile.wxml-->
<view class="page {{theme}}">
  <nav-bar title="我的" bgColor="{{theme === 'dark' ? '#1e1e1e' : '#ffffff'}}" textColor="{{theme === 'dark' ? '#e8e8e8' : '#1a1a1a'}}" />

  <!-- 头部 -->
  <view class="profile-header">
    <view class="avatar">📚</view>
    <view class="header-info">
      <text class="header-title">小程序开发教程</text>
      <text class="header-desc">微信小程序开发学习平台</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">控件</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{hardwareCount}}</text>
      <text class="stat-label">硬件能力</text>
    </view>
    <view class="stat-card" bindtap="goToFavorite">
      <text class="stat-num">{{favCount}}</text>
      <text class="stat-label">我的收藏</text>
    </view>
  </view>

  <!-- 设置列表 -->
  <view class="settings-group">
    <view class="setting-item" bindtap="onToggleTheme">
      <text class="setting-icon">{{theme === 'dark' ? '☀️' : '🌙'}}</text>
      <text class="setting-label">{{theme === 'dark' ? '浅色模式' : '深色模式'}}</text>
      <view class="setting-switch {{theme === 'dark' ? 'on' : ''}}">
        <view class="switch-dot"></view>
      </view>
    </view>
  </view>

  <!-- 硬件演示模式 -->
  <view class="settings-group">
    <view class="setting-item mode-item">
      <text class="setting-icon">🧪</text>
      <text class="setting-label">硬件演示模式</text>
      <view class="seg">
        <view class="seg-item {{hardwareMode === 'simulate' ? 'active' : ''}}"
          data-mode="simulate" bindtap="onSetHardwareMode">模拟</view>
        <view class="seg-item {{hardwareMode === 'real' ? 'active' : ''}}"
          data-mode="real" bindtap="onSetHardwareMode">真机</view>
      </view>
    </view>
    <view class="setting-hint">模拟：用虚拟数据预览效果；真机：调用设备真实能力（需真机预览）</view>
  </view>

  <view class="settings-group">
    <view class="setting-item" bindtap="goToFavorite">
      <text class="setting-icon">⭐</text>
      <text class="setting-label">我的收藏</text>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="goToHistory">
      <text class="setting-icon">📋</text>
      <text class="setting-label">浏览历史</text>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="goToAbout">
      <text class="setting-icon">ℹ️</text>
      <text class="setting-label">关于</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <view class="settings-group">
    <view class="setting-item danger" bindtap="onClearData">
      <text class="setting-icon">🗑</text>
      <text class="setting-label">清除数据</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 赞助作者 -->
  <view class="sponsor-card">
    <view class="sponsor-head">
      <text class="sponsor-icon">💝</text>
      <text class="sponsor-title">赞助作者</text>
    </view>
    <view class="sponsor-desc">
      <text>如果这个小程序帮到了你，欢迎请作者喝杯奶茶 ☕</text>
      <text>一元、两元都是鼓励，随缘就好～</text>
    </view>
    <view class="sponsor-qr-wrap" bindtap="onPreviewSponsor">
      <image class="sponsor-qr" src="/images/sponsor-qr.png" mode="aspectFit" />
    </view>
    <text class="sponsor-tip">长按上方二维码，识别后即可转账</text>
  </view>

  <view class="footer">
    <text>小程序开发教程 v1.0.0</text>
  </view>
</view>
