/* pages/profile/profile.wxss */
.page { min-height: 100vh; padding: 0 32rpx 48rpx; }

/* 头部 */
.profile-header {
  display: flex; align-items: center;
  background: linear-gradient(135deg, #4C8BF5, #6BA0F7);
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx; margin-bottom: 24rpx;
}
.avatar {
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: rgba(255,255,255,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 48rpx;
}
.header-info { margin-left: 24rpx; }
.header-title { font-size: var(--font-xl); font-weight: 700; color: #fff; display: block; }
.header-desc { font-size: var(--font-sm); color: rgba(255,255,255,0.8); margin-top: 4rpx; }

/* 数据统计 */
.stats-grid {
  display: flex; gap: 16rpx; margin-bottom: 32rpx;
}
.stat-card {
  flex: 1; background: var(--bg-card); border-radius: var(--radius-lg);
  padding: 24rpx 0; text-align: center; box-shadow: var(--shadow-card);
}
.stat-num { font-size: 40rpx; font-weight: 700; color: var(--color-primary); display: block; }
.stat-label { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; }

/* 设置列表 */
.settings-group {
  background: var(--bg-card); border-radius: var(--radius-lg);
  overflow: hidden; margin-bottom: 24rpx; box-shadow: var(--shadow-card);
}
.setting-item {
  display: flex; align-items: center;
  padding: 28rpx 28rpx; border-bottom: 1rpx solid var(--border-light);
}
.setting-item:last-child { border-bottom: none; }
.setting-icon { font-size: 36rpx; margin-right: 20rpx; }
.setting-label { flex: 1; font-size: var(--font-md); color: var(--text-primary); }
.setting-item.danger .setting-label { color: var(--color-danger); }
.setting-arrow { font-size: 40rpx; color: var(--text-tertiary); }

/* 自定义开关 */
.setting-switch {
  width: 80rpx; height: 44rpx; border-radius: 22rpx;
  background: #E8E8E8; position: relative; transition: var(--transition);
}
.setting-switch.on { background: var(--color-primary); }
.switch-dot {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: #fff; position: absolute; top: 4rpx; left: 4rpx;
  transition: var(--transition);
}
.setting-switch.on .switch-dot { left: 40rpx; }

/* 分段组件（设备能力模式） */
.mode-item { padding-top: 28rpx; padding-bottom: 28rpx; }
.seg {
  display: flex; background: var(--bg-hover);
  border-radius: var(--radius-full); padding: 4rpx;
}
.seg-item {
  padding: 10rpx 32rpx; font-size: var(--font-sm); color: var(--text-secondary);
  border-radius: var(--radius-full); transition: var(--transition);
}
.seg-item.active { background: var(--color-primary); color: #fff; font-weight: 600; }
.setting-hint {
  padding: 0 28rpx 24rpx; font-size: var(--font-xs);
  color: var(--text-tertiary); line-height: 1.5;
}

.footer { text-align: center; padding: 32rpx 0; color: var(--text-tertiary); font-size: var(--font-xs); }

