/* pages/history/history.wxss */
.page { min-height: 100vh; padding: 0 32rpx 48rpx; }
.clear-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.history-count { font-size: 26rpx; color: var(--text-tertiary); }
.clear-btn { font-size: 26rpx; color: var(--color-danger); }
.history-list { background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-card); }
.history-item { display: flex; align-items: center; padding: 24rpx 28rpx; border-bottom: 1rpx solid var(--border-light); }
.history-item:last-child { border-bottom: none; }
.history-name { flex: 1; font-size: var(--font-md); color: var(--text-primary); }
.history-time { font-size: 24rpx; color: var(--text-tertiary); }
.history-arrow { font-size: 36rpx; color: var(--text-tertiary); margin-left: 12rpx; }
.history-empty { padding-top: 80rpx; }
