/* pages/category/category.wxss */
.page {
  min-height: 100vh;
  padding: 0 32rpx 48rpx;
}

/* 分类横幅 */
.cat-banner {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
}
.cat-banner-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}
.cat-banner-info {
  flex: 1;
  margin-left: 20rpx;
}
.cat-banner-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}
.cat-banner-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 控件列表 */
.control-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.control-item {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  box-shadow: var(--shadow-card);
}
.control-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg-tag);
  color: var(--color-primary);
  font-size: var(--font-sm);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.control-content {
  flex: 1;
  margin-left: 20rpx;
}
.control-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.control-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 6rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.control-arrow {
  font-size: 40rpx;
  color: var(--text-tertiary);
  margin-left: 12rpx;
}
