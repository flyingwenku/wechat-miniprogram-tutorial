/* pages/quiz-wrong/quiz-wrong.wxss */
.wrong-page {
  padding: 20rpx 24rpx 60rpx;
}

.wrong-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.wrong-count {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.wrong-actions {
  display: flex;
  gap: 24rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 练习按钮 */
.practice-btn {
  background: var(--color-primary);
  color: #fff;
  text-align: center;
  padding: 26rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.practice-btn:active {
  opacity: 0.85;
}

/* 题目列表 */
.question-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.question-item {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  border-left: 6rpx solid #ee0a24;
}

.q-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.q-tag {
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-light, #e8f0fe);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.q-remove {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.q-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.q-answer {
  display: flex;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.answer-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.answer-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #07c160;
}

.q-explanation {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  background: var(--bg-hover);
  padding: 16rpx;
  border-radius: 10rpx;
}
