/* app.wxss — 全局样式 & 设计系统 */

/* ============ 设计变量 ============ */
page {
  /* 主题色 */
  --color-primary: #4C8BF5;
  --color-primary-light: #6BA0F7;
  --color-primary-dark: #3A6FD9;
  --color-success: #34C759;
  --color-warning: #FF9500;
  --color-danger: #FF3B30;
  --color-info: #8E8E93;

  /* 亮色模式 */
  --bg-page: #f5f6f8;
  --bg-card: #ffffff;
  --bg-hover: #f0f1f3;
  --bg-tag: #eef2ff;
  --bg-code: #f6f8fa;

  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --text-inverse: #ffffff;

  --border-color: #e8e8e8;
  --border-light: #f0f0f0;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  --shadow-float: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);

  /* 尺寸 */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 999rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;

  /* 字号 */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-2xl: 48rpx;

  /* 过渡 */
  --transition: all 0.25s ease;

  font-size: var(--font-md);
  color: var(--text-primary);
  background-color: var(--bg-page);
}

/* ============ 暗色模式 ============ */
page.dark {
  --bg-page: #121212;
  --bg-card: #1e1e1e;
  --bg-hover: #2a2a2a;
  --bg-tag: #1a2333;
  --bg-code: #1a1a1a;

  --text-primary: #e8e8e8;
  --text-secondary: #a0a0a0;
  --text-tertiary: #707070;
  --text-inverse: #1a1a1a;

  --border-color: #333333;
  --border-light: #262626;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  --shadow-float: 0 8rpx 30rpx rgba(0, 0, 0, 0.5);
}

/* ============ 基础重置 ============ */
view, text, scroll-view, image, button, input, textarea {
  box-sizing: border-box;
}

/* ============ 通用类 ============ */
.flex {
  display: flex;
}
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}
.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.flex-col {
  display: flex;
  flex-direction: column;
}
.flex-wrap {
  flex-wrap: wrap;
}
.flex-1 {
  flex: 1;
}

.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.desc-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 文本省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding: var(--space-md);
  padding-bottom: calc(var(--space-xl) + env(safe-area-inset-bottom));
}

/* hover 效果 */
.hover-opacity {
  opacity: 1;
}
.hover-opacity:active {
  opacity: 0.7;
}
.hover-scale {
  transition: var(--transition);
}
.hover-scale:active {
  transform: scale(0.97);
}
